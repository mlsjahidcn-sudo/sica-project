# ============================================
# LLM Configuration (AI Chat Provider)
# ============================================
# Supports MiniMax (recommended) and Moonshot/Kimi as fallback
# Get keys from respective platforms

# MiniMax AI (Primary - Fast & Cost-effective)
# Get API key from: https://platform.minimax.chat/
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat  # Options: abab6.5s-chat, abab6.5-chat, abab6-chat

# Moonshot/Kimi (Fallback - Higher context window)
# Get API key from: https://platform.moonshot.cn/
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5

# Primary LLM Provider (auto-fallback if primary fails)
LLM_PROVIDER=minimax  # Options: 'minimax' or 'moonshot'

# Resend Email Configuration
# Note: To use your own domain (studyinchina.academy), verify it at https://resend.com/domains
RESEND_API_KEY=your-resend-api-key-here
EMAIL_FROM=Team SICA <info@studyinchina.academy>
ADMIN_EMAIL=admin@studyinchina.academy

# Application URL
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ============================================
# 🔴 External Supabase Database (REQUIRED)
# ============================================
# MUST use the external Supabase project: maqzxlcsgfpwnfyleoga
# DO NOT change these values to local or other Supabase projects
COZE_SUPABASE_URL=https://maqzxlcsgfpwnfyleoga.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key-here
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database Connection String
# Format: postgresql://postgres:[PASSWORD]@db.maqzxlcsgfpwnfyleoga.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.maqzxlcsgfpwnfyleoga.supabase.co:5432/postgres
