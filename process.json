{
  "name": "nextjs-app",
  "script": "npx tsx src/server.ts",
  "cwd": ".",
  "instances": 1,
  "exec_mode": "fork",
  "env": {
    "NODE_ENV": "production",
    "PORT": 5000
  },
  "error_file": "./logs/error.log",
  "out_file": "./logs/out.log",
  "pid_file": "./pids/app.pid",
  "autorestart": true,
  "watch": false,
  "max_memory_restart": "1G"
}