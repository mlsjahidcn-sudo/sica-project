# ============================================
# Supabase Configuration (REQUIRED)
# ============================================

# Your Supabase project URL
COZE_SUPABASE_URL=https://maqzxlcsgfpwnfyleoga.supabase.co

# Anonymous/Public key (safe to expose in client-side code, but keep in .env)
COZE_SUPABASE_ANON_KEY=your-anon-key-here

# Service Role key (FULL ADMIN ACCESS - NEVER expose to client-side)
# Get from: Supabase Dashboard → Settings → API → service_role
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Direct database connection string (for migrations, scripts)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-password@db.maqzxlcsgfpwnfyleoga.supabase.co:5432/postgres

# ============================================
# LLM Configuration (Moonshot API - Kimi K2.5)
# ============================================
# Get your API key from: https://platform.moonshot.cn/
# Available models:
#   - kimi-k2.5 (Recommended - Latest Kimi K2.5, most intelligent, 262K context)
#   - kimi-k2-thinking (Kimi K2 with thinking mode, 262K context)
#   - moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k (Legacy models)
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.5

